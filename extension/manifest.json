{
  "manifest_version": 3,
  "name": "Codex RTL Toolkit",
  "version": "0.1.6",
  "description": "Improves mixed RTL/LTR rendering for Arabic-script languages in Codex and ChatGPT.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "css": [
        "rtl-style.css"
      ],
      "js": [
        "rtl-core.js",
        "injected.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
