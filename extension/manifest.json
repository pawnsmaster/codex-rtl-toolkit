{
  "manifest_version": 3,
  "name": "Codex RTL Toolkit",
  "version": "0.1.4",
  "description": "Improves Arabic/English RTL rendering in Codex and ChatGPT conversations.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "css": [
        "rtl-style.css"
      ],
      "js": [
        "injected.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
